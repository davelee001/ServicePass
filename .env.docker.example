# Docker Compose Environment Variables Example
# Copy this file to .env and update with your values

# === Database Configuration ===
MONGODB_PASSWORD=adminpassword

# === Security Secrets (REQUIRED - Change in Production) ===
JWT_SECRET=your-jwt-secret-min-32-characters-long
ENCRYPTION_KEY=your-encryption-key-must-be-32-characters-minimum
QR_SIGNING_SECRET=your-qr-signing-secret-change-this

# === SUI Blockchain Configuration (REQUIRED) ===
PACKAGE_ID=0x...
ADMIN_CAP_ID=0x...
REGISTRY_ID=0x...
ADMIN_PRIVATE_KEY=suiprivkey...

# === Email Configuration (Optional) ===
EMAIL_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@servicepass.com

# === SMS Configuration - Twilio (Optional) ===
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# === Push Notifications - Firebase (Optional) ===
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# === Development Tools ===
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=pass
